# Anthropic (used by the vendored lib/llm cost-aware client)
ANTHROPIC_API_KEY=sk-ant-...

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...   # safe to expose — used for auth in the browser
SUPABASE_SERVICE_ROLE_KEY=eyJ...       # server-only, NEVER expose to the client

# Public base URL used when generating QR codes
NEXT_PUBLIC_BASE_URL=https://reviews.yourdomain.com

# Secret that gates the /onboard admin page — set to a long random string
ONBOARD_SECRET=change-me
